# ============================================================================
# Trellis — Environment Configuration
# Copy this file to .env and uncomment/edit values as needed.
# ============================================================================

# Database (default: local SQLite — works out of the box)
DATABASE_URL=sqlite+aiosqlite:///./trellis.db

# ── LLM Providers ──────────────────────────────────────────────────────────
# Configure at least ONE provider. The seed agents use NVIDIA NIM by default.
#
# NVIDIA NIM (recommended — free tier at build.nvidia.com)
# The seed agents are pre-configured for meta/llama-3.3-70b-instruct via NVIDIA.
NVIDIA_API_KEY=nvapi-...
#
# Other providers (optional — uncomment to enable):
# TRELLIS_OPENAI_API_KEY=sk-...
# TRELLIS_GROQ_API_KEY=gsk_...
# TRELLIS_GOOGLE_API_KEY=AIza...
#
# Local Ollama (for local development only — not available in cloud deploys)
# TRELLIS_OLLAMA_URL=http://localhost:11434/v1

# ── Semantic Routing ───────────────────────────────────────────────────────
# Embedding model for semantic similarity scoring in intelligent routing.
# Auto-downloads on first use (~80MB). Default: all-MiniLM-L6-v2
# TRELLIS_EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Azure Bot Service (Teams integration) ─────────────────────────────────
# TEAMS_APP_ID=
# TEAMS_APP_PASSWORD=

# ── Server ─────────────────────────────────────────────────────────────────
# TRELLIS_HOST=0.0.0.0
# TRELLIS_PORT=8000
