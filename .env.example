# ============================================================================
# Trellis — Environment Configuration
# Copy this file to .env and uncomment/edit values as needed.
# ============================================================================

# Database (default: local SQLite — works out of the box)
DATABASE_URL=sqlite+aiosqlite:///./trellis.db

# ── LLM Providers ──────────────────────────────────────────────────────────
# Ollama is the default provider — no API key needed.
# Install Ollama (https://ollama.com), pull a model, and agents work immediately.
TRELLIS_OLLAMA_URL=http://localhost:11434/v1

# Uncomment to enable cloud providers (optional):
# TRELLIS_OPENAI_API_KEY=sk-...
# TRELLIS_GROQ_API_KEY=gsk-...
# TRELLIS_GOOGLE_API_KEY=...
# NVIDIA_API_KEY=nvapi-...

# ── Semantic Routing ───────────────────────────────────────────────────────
# Embedding model for semantic similarity scoring in intelligent routing.
# Auto-downloads on first use (~80MB). Default: all-MiniLM-L6-v2
# TRELLIS_EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Azure Bot Service (Teams integration) ─────────────────────────────────
# TEAMS_APP_ID=
# TEAMS_APP_PASSWORD=

# ── Server ─────────────────────────────────────────────────────────────────
# TRELLIS_HOST=0.0.0.0
# TRELLIS_PORT=8000
